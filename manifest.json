{
  "manifest_version": 3,
  "name": "BossSay - Boss直聘AI智能打招呼助手",
  "version": "2.0.0",
  "description": "基于AI的Boss直聘智能打招呼插件，读取岗位JD并结合你的简历生成个性化消息，提高HR回复率",
  "author": "XN-289",
  "homepage_url": "https://github.com/XN-289/Bosssay-a-boss-ai-assistant",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://www.zhipin.com/*",
    "https://zhipin.com/*",
    "https://*.zhipin.com/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://*.openai.com/*",
    "https://api.anthropic.com/*",
    "https://*.anthropic.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.zhipin.com/job_detail/*",
        "https://zhipin.com/job_detail/*",
        "https://www.zhipin.com/web/geek/job/*",
        "https://zhipin.com/web/geek/job/*",
        "https://www.zhipin.com/*",
        "https://zhipin.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "options/options.html"
}
